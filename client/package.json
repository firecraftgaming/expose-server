{
  "name": "expose-client",
  "version": "0.1.0",
  "description": "CLI client for the Expose tunneling server",
  "type": "module",
  "bin": {
    "expose": "./dist/cli.js"
  },
  "scripts": {
    "build": "npm run build:dashboard && tsc && rm -rf dist/dashboard/public && cp -r src/dashboard/public dist/dashboard/public",
    "build:dashboard": "cd dashboard && (test -d node_modules || npm ci) && npm run build",
    "dev": "npm run build:dashboard && tsx src/cli.ts",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "express": "^4.21.2",
    "no-try": "^3.1.0",
    "ora": "^8.2.0",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.30",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/ws": "^8.5.14",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
